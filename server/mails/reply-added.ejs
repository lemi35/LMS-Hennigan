<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>New Reply to Your Question</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f6f8; font-family:Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f6f8; padding:20px 0;">
    <tr>
      <td align="center">
        
        <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:8px; padding:30px;">
          
          <!-- Header -->
          <tr>
            <td align="center">
              <h2 style="margin:0; color:#333;">New Reply to Your Question 💬</h2>
            </td>
          </tr>

          <!-- Spacer -->
          <tr>
            <td height="20"></td>
          </tr>

          <!-- Greeting -->
          <tr>
            <td>
              <p style="font-size:16px; color:#555;">
                Hi <strong><%= userName %></strong>,
              </p>

              <p style="font-size:15px; color:#555;">
                Good news! Someone has replied to your question in the course:
              </p>

              <p style="font-size:16px; font-weight:bold; color:#111;">
                <%= courseName %>
              </p>
            </td>
          </tr>

          <!-- Question -->
          <tr>
            <td style="padding-top:15px;">
              <p style="margin:0; font-weight:bold;">Your Question:</p>
              <p style="background:#f1f3f5; padding:12px; border-radius:5px;">
                <%= question %>
              </p>
            </td>
          </tr>

          <!-- Reply -->
          <tr>
            <td style="padding-top:15px;">
              <p style="margin:0; font-weight:bold;">New Reply:</p>
              <p style="background:#e7f5ff; padding:12px; border-radius:5px;">
                <%= reply %>
              </p>
            </td>
          </tr>

          <!-- Button -->
          <tr>
            <td align="center" style="padding-top:25px;">
              <a href="<%= courseUrl %>" 
                 style="display:inline-block; padding:12px 20px; background:#2563eb; color:#ffffff; text-decoration:none; border-radius:5px;">
                View Discussion
              </a>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding-top:30px; font-size:13px; color:#888; text-align:center;">
              If you didn’t expect this notification, you can safely ignore it.
              <br/><br/>
              © <%= new Date().getFullYear() %> Your LMS Platform
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>